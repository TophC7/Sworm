            }
          ],
          "regexFlag": "gm",
          "regexLimit": 25000
        },
        {
          // LINE COMMENTS :D
          "regex": "(?<=\\s*)(//|#|;)(.|\r\n)*?$",
          "regexes": [
            {
              "decorations": [
                {
                  "color": "#d4be98",
                  "fontWeight": "bold",
                  "index": 0
                }
              ],
              "regex": "\\B:D"
            },
