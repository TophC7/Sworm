{
  "id": "dev.sworm.html",
  "label": "HTML",
  "contributes": {
    "languages": [
      {
        "id": "html",
        "label": "HTML",
        "aliases": ["html"],
        "extensions": [".html", ".htm"]
      }
    ],
    "lsp_servers": [
      {
        "id": "vscode-html-language-server",
        "label": "HTML Language Server",
        "applies_to_languages": ["html"],
        "runtime": {
          "kind": "host_binary",
          "command": "vscode-html-language-server"
        },
        "args": ["--stdio"],
        "install_hint": "Install `vscode-langservers-extracted` and ensure `vscode-html-language-server` is on PATH.",
        "document_selectors": [
          {
            "language": "html",
            "extensions": [".html", ".htm"]
          }
        ],
        "settings": {
          "section": "html",
          "schema_path": "./settings.schema.json"
        }
      }
    ]
  }
}
