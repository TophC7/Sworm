{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CSS / SCSS / Less Language Server Settings",
  "description": "Settings forwarded to the VS Code-based CSS language server. Top-level subsections mirror VS Code's `css.*`, `scss.*`, and `less.*`. Every lint rule accepts 'ignore', 'warning', or 'error'.",
  "type": "object",
  "additionalProperties": true,
  "definitions": {
    "severity": { "type": "string", "enum": ["ignore", "warning", "error"] },
    "languageBlock": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "validate": { "type": "boolean", "default": true },
        "completion": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "triggerPropertyValueCompletion": { "type": "boolean", "default": true },
            "completePropertyWithSemicolon": { "type": "boolean", "default": true }
          }
        },
        "hover": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "documentation": { "type": "boolean", "default": true },
            "references": { "type": "boolean", "default": true }
          }
        },
        "lint": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "compatibleVendorPrefixes": { "$ref": "#/definitions/severity", "default": "ignore" },
            "vendorPrefix": { "$ref": "#/definitions/severity", "default": "warning" },
            "duplicateProperties": { "$ref": "#/definitions/severity", "default": "ignore" },
            "emptyRules": { "$ref": "#/definitions/severity", "default": "warning" },
            "importStatement": { "$ref": "#/definitions/severity", "default": "ignore" },
            "boxModel": { "$ref": "#/definitions/severity", "default": "ignore" },
            "universalSelector": { "$ref": "#/definitions/severity", "default": "ignore" },
            "zeroUnits": { "$ref": "#/definitions/severity", "default": "ignore" },
            "fontFaceProperties": { "$ref": "#/definitions/severity", "default": "warning" },
            "hexColorLength": { "$ref": "#/definitions/severity", "default": "error" },
            "argumentsInColorFunction": { "$ref": "#/definitions/severity", "default": "error" },
            "unknownProperties": { "$ref": "#/definitions/severity", "default": "warning" },
            "unknownVendorSpecificProperties": { "$ref": "#/definitions/severity", "default": "ignore" },
            "propertyIgnoredDueToDisplay": { "$ref": "#/definitions/severity", "default": "warning" },
            "important": { "$ref": "#/definitions/severity", "default": "ignore" },
            "float": { "$ref": "#/definitions/severity", "default": "ignore" },
            "idSelector": { "$ref": "#/definitions/severity", "default": "ignore" }
          }
        }
      }
    }
  },
  "properties": {
    "css": { "$ref": "#/definitions/languageBlock" },
    "scss": { "$ref": "#/definitions/languageBlock" },
    "less": { "$ref": "#/definitions/languageBlock" }
  }
}
