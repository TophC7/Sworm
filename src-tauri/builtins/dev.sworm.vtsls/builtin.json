{
  "id": "dev.sworm.vtsls",
  "label": "TypeScript",
  "contributes": {
    "languages": [
      {
        "id": "javascript",
        "label": "JavaScript",
        "aliases": ["js"],
        "extensions": [".js", ".jsx", ".mjs", ".cjs"]
      },
      {
        "id": "typescript",
        "label": "TypeScript",
        "aliases": ["ts"],
        "extensions": [".ts", ".tsx", ".mts", ".cts"]
      }
    ],
    "lsp_servers": [
      {
        "id": "vtsls",
        "label": "vtsls",
        "applies_to_languages": ["javascript", "typescript"],
        "runtime": {
          "kind": "host_binary",
          "command": "vtsls"
        },
        "args": ["--stdio"],
        "install_hint": "Install `@vtsls/language-server` and ensure `vtsls` is on PATH.",
        "document_selectors": [
          {
            "language": "javascript",
            "extensions": [".js", ".jsx", ".mjs", ".cjs"]
          },
          {
            "language": "typescript",
            "extensions": [".ts", ".tsx", ".mts", ".cts"]
          }
        ],
        "settings": {
          "section": "typescript",
          "schema_path": "./settings.schema.json"
        }
      }
    ]
  }
}
