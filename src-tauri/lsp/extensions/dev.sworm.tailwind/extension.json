{
  "id": "dev.sworm.tailwind",
  "label": "Tailwind CSS",
  "servers": [
    {
      "id": "tailwindcss-language-server",
      "label": "Tailwind CSS Language Server",
      "runtime": {
        "kind": "host_binary",
        "command": "tailwindcss-language-server"
      },
      "args": ["--stdio"],
      "install_hint": "Install `@tailwindcss/language-server` and ensure `tailwindcss-language-server` is on PATH.",
      "document_selectors": [
        {
          "language": "svelte",
          "extensions": [".svelte"]
        },
        {
          "language": "html",
          "extensions": [".html", ".htm"]
        },
        {
          "language": "css",
          "extensions": [".css", ".pcss", ".postcss", ".scss"]
        },
        {
          "language": "javascript",
          "extensions": [".js", ".jsx", ".mjs", ".cjs"]
        },
        {
          "language": "typescript",
          "extensions": [".ts", ".tsx", ".mts", ".cts"]
        }
      ]
    }
  ]
}
