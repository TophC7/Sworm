{
  "id": "dev.sworm.vtsls",
  "label": "TypeScript",
  "languages": [
    {
      "id": "javascript",
      "label": "JavaScript",
      "aliases": ["js"],
      "extensions": [".js", ".jsx", ".mjs", ".cjs"]
    },
    {
      "id": "typescript",
      "label": "TypeScript",
      "aliases": ["ts"],
      "extensions": [".ts", ".tsx", ".mts", ".cts"]
    }
  ],
  "servers": [
    {
      "id": "vtsls",
      "label": "vtsls",
      "runtime": {
        "kind": "host_binary",
        "command": "vtsls"
      },
      "args": ["--stdio"],
      "install_hint": "Install `@vtsls/language-server` and ensure `vtsls` is on PATH.",
      "document_selectors": [
        {
          "language": "javascript",
          "extensions": [".js", ".jsx", ".mjs", ".cjs"]
        },
        {
          "language": "typescript",
          "extensions": [".ts", ".tsx", ".mts", ".cts"]
        }
      ]
    }
  ]
}
