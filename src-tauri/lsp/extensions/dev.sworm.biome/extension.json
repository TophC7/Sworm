{
  "id": "dev.sworm.biome",
  "label": "Biome",
  "servers": [
    {
      "id": "biome",
      "label": "Biome",
      "runtime": {
        "kind": "host_binary",
        "command": "biome"
      },
      "args": ["lsp-proxy"],
      "install_hint": "Install Biome so `biome` is available on PATH",
      "document_selectors": [
        {
          "language": "javascript",
          "extensions": [".js", ".jsx", ".mjs", ".cjs"]
        },
        {
          "language": "typescript",
          "extensions": [".ts", ".tsx", ".mts", ".cts", ".d.ts"]
        },
        {
          "language": "json",
          "extensions": [".json", ".jsonc"]
        }
      ]
    }
  ]
}
